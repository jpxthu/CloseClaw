#!/bin/bash
# Commit-msg hook: validates Source: and Type: footers
# Mirrors CI check in .github/workflows/ci.yml

set -e

msg=$(cat "$1")

echo "=== Commit message ==="
echo "$msg"
echo ""

# 1. Check Source: footer
if ! echo "$msg" | grep -qE '^Source: (issue #[0-9]+|Fixes #|Refs #|Closes #|CI|user)'; then
    echo "ERROR: Source footer must be one of:"
    echo "  - issue #N"
    echo "  - Fixes #N / Refs #N / Closes #N (legacy)"
    echo "  - CI"
    echo "  - user"
    echo ""
    echo "Commit message:"
    echo "$msg"
    exit 1
fi

# 2. Check Type: footer
valid_types="feat|fix|docs|refactor|test|perf|chore"
if ! echo "$msg" | grep -qE "^Type: ($valid_types)"; then
    echo "ERROR: Type footer must be one of: $valid_types"
    echo ""
    echo "Commit message:"
    echo "$msg"
    exit 1
fi

# 3. Remind agent to verify commit author matches their session identity
actual_author=$(git config user.name 2>/dev/null | tr -d '\n')
actual_email=$(git config user.email 2>/dev/null | tr -d '\n')
if [[ -n "$actual_author" ]]; then
    echo "NOTE: Current commit author is '$actual_author <$actual_email>'"
    echo "      If this is not your agent identity, fix with:"
    echo "      git commit --amend --author 'Your Name <your@email>' --no-edit"
    echo ""
fi

echo "Commit message check passed"
echo "- Source: $(echo "$msg" | grep '^Source:' | sed 's/^Source: //')"
echo "- Type: $(echo "$msg" | grep '^Type:' | sed 's/^Type: //')"
