{
  "protocol": "openai",
  "streaming": true,
  "scenario": "tool-use-streaming",
  "model": "glm-5",
  "expect": "tool_calls_streaming",
  "request": {
    "model": "glm-5",
    "messages": [
      {
        "role": "user",
        "content": "How's the weather in San Francisco?"
      }
    ]
  },
  "tools_sent": [
    {
      "type": "function",
      "function": {
        "name": "get_weather",
        "description": "Get the current weather in a given location.",
        "parameters": {
          "type": "object",
          "properties": {
            "location": {
              "type": "string",
              "description": "City name, e.g. Tokyo"
            }
          },
          "required": [
            "location"
          ]
        }
      }
    }
  ]
}